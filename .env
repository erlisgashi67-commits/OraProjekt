# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=oraprojekt-dev-secret-2026-CHANGE-IN-PRODUCTION
AUTH_URL=http://localhost:3000

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — get from https://entra.microsoft.com → App registrations
# Authorized redirect URI: http://localhost:3000/api/auth/callback/azure-ad
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Legacy session secret (kept for backward compat)
SESSION_SECRET=oraprojekt-dev-secret-2026
