# =============================================================================
# OraProjekt — Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# Database
# For development: SQLite (file-based)
# For production: PostgreSQL (e.g. postgresql://user:pass@host:5432/dbname)
DATABASE_URL=file:./db/custom.db

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=oraprojekt-dev-secret-2026-CHANGE-IN-PRODUCTION
AUTH_URL=http://localhost:3000

# Legacy session secret (kept for backward compat)
SESSION_SECRET=oraprojekt-dev-secret-2026

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use existing)
# 2. Enable Google+ API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 5. Copy Client ID and Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — get from https://entra.microsoft.com → App registrations
# 1. Register a new application
# 2. Add Redirect URI: http://localhost:3000/api/auth/callback/azure-ad
# 3. Create client secret
# 4. Copy Application (client) ID and Secret below
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
